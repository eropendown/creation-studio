# ═══════════════════════════════════════════════
#  创作工作室 · 环境变量配置
# ═══════════════════════════════════════════════

# ── LLM ────────────────────────────────────────
# 提供商: openai | deepseek | mock
# 使用 mock 不需要真实 API Key，适合本地调试

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# DeepSeek（性价比更高）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── TTS 配音 ────────────────────────────────────
# 提供商: edge_tts(免费默认) | openai | elevenlabs | volcengine | mock
# edge_tts 无需配置，开箱即用

# 火山引擎 TTS（可选，需开通语音合成服务）
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_ACCESS_KEY=
VOLCENGINE_TTS_SECRET_KEY=
VOLCENGINE_TTS_CLUSTER=volcano_tts

# ElevenLabs（可选）
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── 视频生成 ────────────────────────────────────
# 火山引擎 Seedance 视频生成（需开通方舟平台）
VOLCENGINE_VIDEO_API_KEY=
VOLCENGINE_VIDEO_MODEL=seedance-2.0

# ── 服务器 ──────────────────────────────────────
HOST=0.0.0.0
PORT=8000
